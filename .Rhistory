#########################################
# AQEval examples
#########################################
#########################################
# install AQEval, openair and dplyr from CRAN
# (if you do not already have themâ€¦)
install.packages(c("AQEval", "openair", "dplyr"))
#install AQEval
require(AQEval)
?dplyr::join
#########################################
# AQEval examples
#########################################
#########################################
# install AQEval, openair and dplyr from CRAN
# (if you do not already have themâ€¦)
##install.packages(c("AQEval", "openair", "dplyr"))
#install AQEval
require(AQEval)
#########################################
# use openair and dplyr to make example data
# 1998-2005 data from London Marylebone Road AURN site
# (heavily trafficked roadside site in central London)
# (getting from AURN archive)
aq.my1 <- openair::importAURN("my1", year=1998:2005)
# 1998-2005 data from Ealing Acton Town Hall KCL site
# (nearby roadside site but less traffic)
# (getting from KCL archive)
aq.ea2 <- openair::importKCL("ea2", year=1998:2005, met=TRUE)
# 1998-2005 data from Kensington and Chelsea North Kensington KCL site
# (another nearby site but urban background)
# (getting from KCL archive)
aq.kc1 <- openair::importKCL("kc1", year=1998:2005)
# adding Kensington and Chelsea NO2 Ealing as background NO2
aq.ea2 <- dplyr::left_join(aq.ea2,  aq.kc1[c("date", "no2")],
by="date", suffix=c("", ".bg"))
aq.eq2
aq.ea2
#########################################
# trivial example: detecting large change
# NO2 at Marylebone Road
#########################################
# data 1 hour resolution
# converting to 1 day resolution
aq.my1.day <- openair::timeAverage(aq.my1, "day")
# testing for break-points/segments
quantBreakSegments(aq.my1.day, "no2",
ylab="AURN Marylebone Road no2 [ug/m3] \n Break-Segments")
#########################################
# options to optimise find/test/quantify methods
# (again using NO2 at Marylebone Road)
#########################################
# 1. vary input data time resolution
#    (e.g. week faster but sensitivity to change reduced)
aq.my1.day <- openair::timeAverage(aq.my1, "day")
# 2.  find potential break-points
#     (use h to modify break-window size)
#     (h=0.15 default break-windows = 15% of full time-series length)
bpts <- findBreakPoints(aq.my1.day, "no2", h=0.15)
# 3. test for break-points/segments
#    (this compares different combinations of break-points
#    (and recommends a break-point combination)
testBreakPoints(aq.my1.day, "no2", bpts)
# 4. quantify as break-points
quantifyBreakPoints(aq.my1.day, "no2", bpts)
#########################################
# options to optimise find/test/quantify methods
# (again using NO2 at Marylebone Road)
#########################################
# 1. vary input data time resolution
#    (e.g. week faster but sensitivity to change reduced)
aq.my1.day <- openair::timeAverage(aq.my1, "day")
# 2.  find potential break-points
#     (use h to modify break-window size)
#     (h=0.15 default break-windows = 15% of full time-series length)
bpts <- findBreakPoints(aq.my1.day, "no2", h=0.15)
# 3. test for break-points/segments
#    (this compares different combinations of break-points
#    (and recommends a break-point combination)
testBreakPoints(aq.my1.day, "no2", bpts)
# 4. quantify as break-points
quantBreakPoints(aq.my1.day, "no2", bpts)
#   (above uses all proposed break-points)
#   (replace bpts with bpts[n:m,] to test just n:m breaks)
#   (e.g. bpts[2,] if using test recommendation)
# 5. quantify as break-segments
quantBreakSegments(aq.my1.day, "no2", bpts)
#########################################
# Two-step workflow, signal isolation then analysis
# NO2 at Ealing
#########################################
# data 1 hour resolution
# converting to 1 day resolution
aq.ea2.day <- timeAverage(aq.ea2, "day")
#########################################
# Two-step workflow, signal isolation then analysis
# NO2 at Ealing
#########################################
# data 1 hour resolution
# converting to 1 day resolution
aq.ea2.day <- openair::timeAverage(aq.ea2, "day")
# Ealing break-segment, using default settings
quantBreakSegments(aq.ea2.day, "no2",
ylab="KCL Ealing Acton Town Hall no2 [ug/m3] + Break-Points")
#########################################
# Two-step workflow, signal isolation then analysis
# NO2 at Ealing
#########################################
# data 1 hour resolution
# converting to 1 day resolution
aq.ea2.day <- openair::timeAverage(aq.ea2, "day")
# Ealing break-segment, using default settings
quantBreakPoints(aq.ea2.day, "no2",
ylab="KCL Ealing Acton Town Hall no2 [ug/m3] + Break-Points")
#########################################
# Two-step workflow, signal isolation then analysis
# NO2 at Ealing
#########################################
# data 1 hour resolution
# converting to 1 day resolution
aq.ea2.day <- openair::timeAverage(aq.ea2, "day")
# Ealing break-points
quantBreakSegments(aq.ea2.day, "no2",
ylab="KCL Ealing Acton Town Hall no2 [ug/m3] + Break-Points")
#########################################
# Two-step workflow, signal isolation then analysis
# NO2 at Ealing
#########################################
# data 1 hour resolution
# converting to 1 day resolution
aq.ea2.day <- openair::timeAverage(aq.ea2, "day")
# Ealing break-points
quantBreakSegments(aq.ea2.day, "no2", test=FALSE,
ylab="KCL Ealing Acton Town Hall no2 [ug/m3] + Break-Points")
citation()
